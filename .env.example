# Supabase — project is already provisioned and schema.sql already run.
# The publishable/secret key format (sb_publishable_... / sb_secret_...) works
# identically to the legacy JWT-style anon/service_role keys.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-side ONLY. Bypasses RLS. Never expose to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Single shared admin password for /dashboard. The site owner picks this.
ADMIN_PASSWORD=change-me
